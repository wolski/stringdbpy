# Snakefile for STRING-GSEA batch processing
#
# Available rules:
#   all          - Run GSEA + render reports for all datasets (default)
#   ci           - Run only small datasets tagged with "ci"
#   run_<NAME>   - Run a single dataset (e.g., run_mouse_xlsx)
#   clean        - Remove all outputs
#   help         - Show this help message

from pathlib import Path

from string_gsea.workflow.helpers import (
    get_ci_datasets,
    get_datasets,
    load_params,
    package_results,
    render_report,
    resolve_template_dirs,
    run_gsea,
)

# Configuration (overridable via --config datasets_dir=... output_dir=...)
DATASETS_DIR = Path(config.get("datasets_dir", "data/datasets"))
OUTPUT_DIR = Path(config.get("output_dir", "data/outputs"))
DATASETS = get_datasets(DATASETS_DIR)
TEMPLATES_DIR, VIGNETTES_DIR = resolve_template_dirs()

localrules: help, clean, ci


# Default target: full pipeline through packaging
rule all:
    input:
        expand(OUTPUT_DIR / "{dataset}" / "outputs.yml", dataset=DATASETS)


# Run GSEA analysis for a dataset
rule run_gsea:
    input:
        zip_file=DATASETS_DIR / "{dataset}" / "input.zip",
        params_file=DATASETS_DIR / "{dataset}" / "params.yml"
    output:
        done=OUTPUT_DIR / "{dataset}" / "gsea_done.txt"
    log:
        "logs/{dataset}/gsea.log"
    run:
        p = load_params(wildcards.dataset, DATASETS_DIR)
        run_gsea(
            zip_file=str(input.zip_file),
            workunit_id=p["execution"]["workunit_id"],
            output_dir=str(OUTPUT_DIR / wildcards.dataset),
            from_rnk=p["input"]["from_rnk"],
            which=p["input"].get("which"),
            done_file=str(output.done),
        )


# Render Quarto reports into WU_{id}_GSEA/
rule render_report:
    input:
        done=OUTPUT_DIR / "{dataset}" / "gsea_done.txt"
    output:
        done=OUTPUT_DIR / "{dataset}" / "render_done.txt"
    log:
        "logs/{dataset}/render.log"
    run:
        p = load_params(wildcards.dataset, DATASETS_DIR)
        render_report(
            dataset_dir=str(OUTPUT_DIR / wildcards.dataset),
            workunit_id=p["execution"]["workunit_id"],
            vignettes_dir=str(VIGNETTES_DIR),
            templates_dir=str(TEMPLATES_DIR),
            done_file=str(output.done),
        )


# Zip WU_{id}_GSEA/ and write outputs.yml
rule package_results:
    input:
        done=OUTPUT_DIR / "{dataset}" / "gsea_done.txt",
        render=OUTPUT_DIR / "{dataset}" / "render_done.txt"
    output:
        yml=OUTPUT_DIR / "{dataset}" / "outputs.yml"
    run:
        p = load_params(wildcards.dataset, DATASETS_DIR)
        package_results(
            output_base=str(OUTPUT_DIR / wildcards.dataset),
            workunit_id=p["execution"]["workunit_id"],
            outputs_yml_path=str(output.yml),
        )


# Run only small datasets tagged with "ci"
rule ci:
    input:
        expand(
            OUTPUT_DIR / "{dataset}" / "outputs.yml",
            dataset=get_ci_datasets(DATASETS, DATASETS_DIR),
        )


# Run a single dataset by name (use as target: snakemake run_mouse_xlsx)
for ds in DATASETS:
    rule:
        name: f"run_{ds}"
        input:
            OUTPUT_DIR / ds / "gsea_done.txt"


# Clean outputs
rule clean:
    shell:
        "rm -rf {OUTPUT_DIR}/* logs/"


# Help message
rule help:
    run:
        ci_ds = get_ci_datasets(DATASETS, DATASETS_DIR)
        print(f"""
STRING-GSEA Snakemake Workflow
==============================

Usage: snakemake [rule] --cores N

Available rules:
  all          - Run GSEA + render reports for all datasets (default)
  ci           - Run only small datasets tagged with "ci" (fast)
  run_<NAME>   - Run a single dataset (e.g., run_mouse_xlsx)
  clean        - Remove all outputs
  help         - Show this help message

Datasets discovered: {', '.join(DATASETS)}

CI datasets (tagged "ci"): {', '.join(ci_ds)}

Examples:
  string_gsea_workflow --cores 1          # Run all datasets
  string_gsea_workflow --target ci        # Run CI datasets only
  string_gsea_workflow --dry-run          # Dry-run
        """)
