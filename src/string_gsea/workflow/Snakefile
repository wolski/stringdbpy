# Snakefile for STRING-GSEA single-dataset processing
#
# Usage:
#   snakemake --config zip_path=... workunit_id=... out_dir=... [which=...] [fdr=...]
#
# Or via the CLI wrapper:
#   string_gsea_workflow input.zip WU123 ./output --which pep_1 --fdr 0.1
#
# Set which=none for RNK input (default: pep_2_no_imputed for XLSX)

from pathlib import Path

from string_gsea.workflow.helpers import resolve_template_dirs

# Configuration from --config key=value
ZIP_PATH = config["zip_path"]
WORKUNIT_ID = str(config["workunit_id"])
OUT_DIR = Path(config.get("out_dir", "."))
WHICH = config.get("which", "pep_2_no_imputed")
FDR = config.get("fdr", None)
TEMPLATES_DIR, VIGNETTES_DIR = resolve_template_dirs()

# Build the string_gsea_run CLI command
_gsea_cmd_parts = ["string_gsea_run", ZIP_PATH, WORKUNIT_ID, str(OUT_DIR), "--which", WHICH]
if FDR is not None:
    _gsea_cmd_parts.extend(["--fdr", str(FDR)])
GSEA_CMD = " ".join(_gsea_cmd_parts)


# Default target: full pipeline through packaging
rule all:
    input:
        OUT_DIR / "outputs.yml"


# Run GSEA analysis
rule run_gsea:
    input:
        zip_file=ZIP_PATH
    output:
        done=OUT_DIR / "gsea_done.txt"
    log:
        str(OUT_DIR / "gsea.log")
    shell:
        """
        {GSEA_CMD} 2>&1 | tee {log}
        touch {output.done}
        """


# Render Quarto reports
rule render_report:
    input:
        done=OUT_DIR / "gsea_done.txt"
    output:
        done=OUT_DIR / "render_done.txt"
    log:
        str(OUT_DIR / "render.log")
    shell:
        """
        _string_gsea_render {OUT_DIR} {WORKUNIT_ID} {VIGNETTES_DIR} {TEMPLATES_DIR} {output.done} 2>&1 | tee {log}
        """


# Zip results and write outputs.yml
rule package_results:
    input:
        done=OUT_DIR / "gsea_done.txt",
        render=OUT_DIR / "render_done.txt"
    output:
        yml=OUT_DIR / "outputs.yml"
    shell:
        """
        _string_gsea_package {OUT_DIR} {WORKUNIT_ID} {output.yml}
        """


# Clean outputs
rule clean:
    shell:
        "rm -rf {OUT_DIR}/*"


# Help message
rule help:
    run:
        print("""
STRING-GSEA Snakemake Workflow
==============================

Usage:
  string_gsea_workflow <zip_path> <workunit_id> <out_dir> [options]

Options:
  --which TEXT     Analysis type: pep_1, pep_1_no_imputed, pep_2, pep_2_no_imputed, or none for RNK input (default: pep_2_no_imputed)
  --fdr FLOAT      FDR threshold (default: from config.toml)
  --cores INT      Number of cores (default: 1)
  --dry-run        Show what would be done without executing
        """)
