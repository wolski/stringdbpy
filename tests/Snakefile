# Snakefile for STRING-GSEA batch processing
# Run from tests/ directory: snakemake --cores 1
#
# Available rules:
#   all          - Run GSEA + render reports for all datasets (default)
#   ci           - Run only small datasets tagged with "ci"
#   run_<NAME>   - Run a single dataset (e.g., run_mouse_xlsx)
#   clean        - Remove all outputs
#   help         - Show this help message

import yaml
from pathlib import Path

# Configuration
DATASETS_DIR = Path("data/datasets")
OUTPUT_DIR = Path("data/outputs")


def get_datasets():
    """Discover all datasets with params.yml."""
    datasets = []
    for params_file in DATASETS_DIR.glob("*/params.yml"):
        with open(params_file) as f:
            params = yaml.safe_load(f)
        if not params.get("execution", {}).get("skip_run", False):
            datasets.append(params_file.parent.name)
    return datasets


def load_params(dataset):
    """Load params.yml for a dataset."""
    with open(DATASETS_DIR / dataset / "params.yml") as f:
        return yaml.safe_load(f)


DATASETS = get_datasets()


# R package source directories (relative to tests/)
R_PKG_DIR = Path("../stringGSEAplot")
TEMPLATES_DIR = R_PKG_DIR / "inst" / "templates"
VIGNETTES_DIR = R_PKG_DIR / "vignettes"


# Default target: full pipeline through packaging
rule all:
    input:
        expand(OUTPUT_DIR / "{dataset}" / "outputs.yml", dataset=DATASETS)


# Run GSEA analysis for a dataset
rule run_gsea:
    input:
        zip_file=DATASETS_DIR / "{dataset}" / "input.zip",
        params_file=DATASETS_DIR / "{dataset}" / "params.yml"
    output:
        done=OUTPUT_DIR / "{dataset}" / "gsea_done.txt"
    params:
        from_rnk=lambda wc: load_params(wc.dataset)["input"]["from_rnk"],
        which=lambda wc: load_params(wc.dataset)["input"].get("which"),
        workunit_id=lambda wc: load_params(wc.dataset)["execution"]["workunit_id"]
    shell:
        """
        mkdir -p {OUTPUT_DIR}/{wildcards.dataset}

        # Build command arguments
        FROM_RNK_FLAG=""
        if [ "{params.from_rnk}" = "True" ]; then
            FROM_RNK_FLAG="--from-rnk"
        fi

        WHICH_FLAG=""
        if [ "{params.which}" != "None" ] && [ "{params.which}" != "" ]; then
            WHICH_FLAG="--which {params.which}"
        fi

        # Run GSEA
        string_gsea_run "{input.zip_file}" "{params.workunit_id}" "{OUTPUT_DIR}/{wildcards.dataset}" $FROM_RNK_FLAG $WHICH_FLAG

        touch {output.done}
        """



# Render Quarto reports directly into WU_{id}_GSEA/
rule render_report:
    input:
        done=OUTPUT_DIR / "{dataset}" / "gsea_done.txt"
    output:
        html=OUTPUT_DIR / "{dataset}" / "render_done.txt"
    params:
        workunit_id=lambda wc: load_params(wc.dataset)["execution"]["workunit_id"]
    shell:
        """
        BASEDIR="$(pwd)"
        WU_DIR="$BASEDIR/{OUTPUT_DIR}/{wildcards.dataset}/WU_{params.workunit_id}_GSEA"
        JSON_FILE="WU{params.workunit_id}_gsea_result.json"

        # Copy QMD + support files into WU dir
        cp "{VIGNETTES_DIR}/GSEA_report.qmd" "$WU_DIR/"
        cp "{TEMPLATES_DIR}/index.qmd" "$WU_DIR/"
        cp "{TEMPLATES_DIR}/_fgcz-report.yml" "$WU_DIR/"
        cp "{TEMPLATES_DIR}/fgcz_header_quarto.html" "$WU_DIR/"

        # Render GSEA report and index page
        cd "$WU_DIR"
        quarto render GSEA_report.qmd -P json_path:"$JSON_FILE"
        quarto render index.qmd \
            -P workunit_id:"{params.workunit_id}" -P package_dir:"."

        # Clean up rendering artifacts
        rm -f GSEA_report.qmd index.qmd _fgcz-report.yml fgcz_header_quarto.html
        rm -rf plots GSEA_report_files index_files
        rm -f index.rmarkdown

        touch "$BASEDIR/{output.html}"
        """


# Zip WU_{id}_GSEA/ and write outputs.yml
rule package_results:
    input:
        done=OUTPUT_DIR / "{dataset}" / "gsea_done.txt",
        render=OUTPUT_DIR / "{dataset}" / "render_done.txt"
    output:
        yml=OUTPUT_DIR / "{dataset}" / "outputs.yml"
    params:
        workunit_id=lambda wc: load_params(wc.dataset)["execution"]["workunit_id"]
    run:
        import shutil

        wu_id = params.workunit_id
        base = Path(f"{OUTPUT_DIR}/{wildcards.dataset}")
        wu_gsea = base / f"WU_{wu_id}_GSEA"

        # Zip the directory as-is
        zip_path = str(base / f"WU_{wu_id}_GSEA.zip")
        shutil.make_archive(
            zip_path.removesuffix(".zip"), "zip",
            root_dir=str(wu_gsea.parent), base_dir=wu_gsea.name
        )
        print(f"Package: {Path(zip_path).resolve()}")

        # Write outputs.yml
        outputs_data = {"outputs": [{
            "local_path": str(Path(zip_path).resolve()),
            "store_entry_path": Path(zip_path).name,
            "type": "bfabric_copy_resource",
        }]}
        with open(str(output.yml), "w") as f:
            yaml.dump(outputs_data, f, default_flow_style=False)


# Run only small datasets tagged with "ci"
rule ci:
    input:
        expand(
            OUTPUT_DIR / "{dataset}" / "outputs.yml",
            dataset=[d for d in DATASETS if "ci" in load_params(d).get("metadata", {}).get("tags", [])]
        )


# Run a single dataset by name (use as target: snakemake run_mouse_xlsx)
for ds in DATASETS:
    rule:
        name: f"run_{ds}"
        input:
            OUTPUT_DIR / ds / "gsea_done.txt"


# Clean outputs
rule clean:
    params:
        outdir=str(OUTPUT_DIR)
    shell:
        """
        rm -rf {params.outdir}/*
        """


# Help message
rule help:
    run:
        print("""
STRING-GSEA Snakemake Workflow
==============================

Usage: snakemake [rule] --cores N

Available rules:
  all          - Run GSEA + render reports for all datasets (default)
  ci           - Run only small datasets tagged with "ci" (fast)
  run_<NAME>   - Run a single dataset (e.g., run_mouse_xlsx)
  clean        - Remove all outputs
  help         - Show this help message

Datasets discovered: {}

CI datasets (tagged "ci"): {}

Examples:
  snakemake --cores 1          # Run all datasets
  snakemake ci --cores 1       # Run CI datasets only
  snakemake run_mouse_xlsx     # Run single dataset
  snakemake -n                 # Dry-run
  snakemake clean              # Remove outputs
        """.format(
            ", ".join(DATASETS),
            ", ".join([d for d in DATASETS if "ci" in load_params(d).get("metadata", {}).get("tags", [])])
        ))
